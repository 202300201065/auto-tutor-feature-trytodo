/**resource.wxss**/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #0052d9 0%, #0066ff 100%);
  padding: 40rpx 32rpx;
  color: #fff;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.class-info {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 加载状态 */
.loading-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 资源列表滚动区域 */
.resource-scroll {
  flex: 1;
  height: 0;
}

/* 资源列表 */
.resource-list {
  padding: 24rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.resource-item:active {
  background-color: #f5f5f5;
}

.resource-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 82, 217, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.resource-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.resource-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.resource-meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.resource-size {
  font-size: 24rpx;
  color: #999;
}

.resource-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
}

.resource-action {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
