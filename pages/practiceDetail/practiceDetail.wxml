<!--practiceDetail.wxml-->
<view class="container">
  <!-- 题目导航 -->
  <view class="question-nav">
    <scroll-view class="nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="nav-list">
        <view 
          wx:for="{{questionIdList}}" 
          wx:key="index" 
          class="nav-item {{currentIndex === index ? 'active' : ''}} {{answerRecords[item] ? 'submitted' : ''}}"
          data-index="{{index}}"
          bindtap="goToQuestion"
        >
          {{index + 1}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <t-loading theme="circular" size="40rpx" />
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 题目内容 -->
  <block wx:elif="{{currentQuestion}}">
    <scroll-view class="question-scroll" scroll-y>
      <view class="question-card">
        <!-- 题目头部 -->
        <view class="question-header">
          <view class="question-index">第 {{currentIndex + 1}} / {{questionIdList.length}} 题</view>
          <view class="question-type type-{{currentQuestion.type}}">
            <text wx:if="{{currentQuestion.type === 'single'}}">单选题</text>
            <text wx:elif="{{currentQuestion.type === 'multiple'}}">多选题</text>
            <text wx:elif="{{currentQuestion.type === 'true_false'}}">判断题</text>
            <text wx:elif="{{currentQuestion.type === 'fill'}}">填空题</text>
          </view>
          <view wx:if="{{answerRecords[questionIdList[currentIndex]]}}" class="submitted-badge {{answerRecords[questionIdList[currentIndex]].isCorrect ? 'correct' : 'wrong'}}">
            {{answerRecords[questionIdList[currentIndex]].isCorrect ? '正确' : '错误'}}
          </view>
        </view>

        <!-- 题目标签 -->
        <view wx:if="{{currentQuestion.tags.length > 0}}" class="question-tags">
          <view wx:for="{{currentQuestion.tags}}" wx:key="id" class="tag-item">
            {{item.tagName}}
          </view>
        </view>

        <!-- 题目内容 -->
        <view class="question-content">{{currentQuestion.content}}</view>

        <!-- 单选题选项 -->
        <block wx:if="{{currentQuestion.type === 'single'}}">
          <view class="options-list">
            <view 
              wx:for="{{currentQuestion.options}}" 
              wx:key="id" 
              class="option-item {{userAnswer === item.id ? 'selected' : ''}} {{answerRecords[questionIdList[currentIndex]] && item.id === currentQuestion.correctAnswer ? 'correct' : ''}} {{answerRecords[questionIdList[currentIndex]] && userAnswer === item.id && item.id !== currentQuestion.correctAnswer ? 'wrong' : ''}}"
              data-option="{{item.id}}"
              bindtap="onSingleSelect"
            >
              <view class="option-label">{{item.id}}</view>
              <view class="option-text">{{item.text}}</view>
            </view>
          </view>
        </block>

        <!-- 多选题选项 -->
        <block wx:elif="{{currentQuestion.type === 'multiple'}}">
          <view class="options-list">
            <view 
              wx:for="{{currentQuestion.options}}" 
              wx:key="id" 
              class="option-item multiple {{multipleSelectedMap[item.id] ? 'selected' : ''}} {{answerRecords[questionIdList[currentIndex]] && currentQuestion.correctAnswersMap[item.id] ? 'correct' : ''}} {{answerRecords[questionIdList[currentIndex]] && multipleSelectedMap[item.id] && !currentQuestion.correctAnswersMap[item.id] ? 'wrong' : ''}}"
              data-option="{{item.id}}"
              bindtap="onMultipleSelect"
            >
              <view class="option-checkbox {{multipleSelectedMap[item.id] ? 'checked' : ''}}">
                <t-icon wx:if="{{multipleSelectedMap[item.id]}}" name="check" size="24rpx" color="#fff" />
              </view>
              <view class="option-label">{{item.id}}</view>
              <view class="option-text">{{item.text}}</view>
            </view>
          </view>
        </block>

        <!-- 判断题选项 -->
        <block wx:elif="{{currentQuestion.type === 'true_false'}}">
          <view class="true-false-options">
            <view 
              class="tf-option {{userAnswer === 'true' ? 'selected' : ''}} {{answerRecords[questionIdList[currentIndex]] && currentQuestion.correctAnswer === true ? 'correct' : ''}} {{answerRecords[questionIdList[currentIndex]] && userAnswer === 'true' && currentQuestion.correctAnswer !== true ? 'wrong' : ''}}"
              data-value="true"
              bindtap="onTrueFalseSelect"
            >
              <t-icon name="check-circle" size="48rpx" />
              <text>正确</text>
            </view>
            <view 
              class="tf-option {{userAnswer === 'false' ? 'selected' : ''}} {{answerRecords[questionIdList[currentIndex]] && currentQuestion.correctAnswer === false ? 'correct' : ''}} {{answerRecords[questionIdList[currentIndex]] && userAnswer === 'false' && currentQuestion.correctAnswer !== false ? 'wrong' : ''}}"
              data-value="false"
              bindtap="onTrueFalseSelect"
            >
              <t-icon name="close-circle" size="48rpx" />
              <text>错误</text>
            </view>
          </view>
        </block>

        <!-- 填空题 -->
        <block wx:elif="{{currentQuestion.type === 'fill'}}">
          <view class="fill-blanks">
            <view 
              wx:for="{{currentQuestion.correctAnswers}}" 
              wx:key="index" 
              class="fill-item"
            >
              <view class="fill-label">第 {{index + 1}} 空</view>
              <input 
                class="fill-input {{answerRecords[questionIdList[currentIndex]] ? 'disabled' : ''}} {{answerRecords[questionIdList[currentIndex]] && fillAnswers[index] === item ? 'correct' : ''}} {{answerRecords[questionIdList[currentIndex]] && fillAnswers[index] !== item ? 'wrong' : ''}}"
                placeholder="请输入答案"
                value="{{fillAnswers[index] || ''}}"
                data-index="{{index}}"
                bindinput="onFillInput"
                disabled="{{!!answerRecords[questionIdList[currentIndex]]}}"
              />
              <view wx:if="{{answerRecords[questionIdList[currentIndex]]}}" class="fill-answer">
                正确答案：{{item}}
              </view>
            </view>
          </view>
        </block>

        <!-- 提交按钮区域 -->
        <view class="submit-section">
          <!-- 已截止且未提交 -->
          <view wx:if="{{isEnded && !answerRecords[questionIdList[currentIndex]]}}" class="ended-hint">
            <t-icon name="time-filled" size="40rpx" color="#999" />
            <text>练习已截止，无法提交</text>
          </view>
          <!-- 未提交且未截止 -->
          <t-button 
            wx:elif="{{!answerRecords[questionIdList[currentIndex]]}}"
            theme="primary" 
            size="large"
            block
            loading="{{submitting}}"
            bindtap="submitAnswer"
          >
            提交答案
          </t-button>
          <!-- 已提交 -->
          <view wx:else class="submitted-hint">
            <t-icon name="check-circle-filled" size="40rpx" color="#52c41a" />
            <text>已提交</text>
          </view>
        </view>

        <!-- 解析（已提交后显示） -->
        <view wx:if="{{answerRecords[questionIdList[currentIndex]] && currentQuestion.analysis}}" class="analysis-section">
          <view class="analysis-title">
            <t-icon name="lightbulb" size="32rpx" color="#faad14" />
            <text>解析</text>
          </view>
          <view class="analysis-content">{{currentQuestion.analysis}}</view>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <t-button 
        theme="default" 
        size="large" 
        disabled="{{currentIndex === 0}}"
        bindtap="prevQuestion"
        style="flex: 1;"
      >
        上一题
      </t-button>
      <t-button 
        theme="primary" 
        size="large" 
        variant="outline"
        disabled="{{currentIndex === questionIdList.length - 1}}"
        bindtap="nextQuestion"
        style="flex: 1; margin-left: 24rpx;"
      >
        下一题
      </t-button>
    </view>
  </block>
</view>

<t-toast id="t-toast" />
